# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Register this as an Authorized redirect URI: {GOOGLE_AUTH_REDIRECT_URI}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:4200

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Restrict sign-in to a specific email domain (optional)
# ALLOWED_EMAIL_DOMAIN=turing.com

# Supabase — find these in your Supabase project: Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# GitHub OAuth App — create at github.com/settings/developers
# Callback URL: {NEXTAUTH_URL}/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# E2B — find your API key at e2b.dev/dashboard
E2B_API_KEY=

# Anthropic — for the NL query agent
ANTHROPIC_API_KEY=
